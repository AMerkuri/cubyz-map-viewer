{
  "name": "cubyz-map-viewer",
  "version": "1.0.0",
  "description": "Interactive 2D & 3D map viewer for Cubyz worlds",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "express": "^5.1.0",
    "sharp": "^0.33.5",
    "chokidar": "^4.0.3",
    "ws": "^8.18.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "leaflet": "^1.9.4",
    "react-leaflet": "^5.0.0",
    "three": "^0.175.0",
    "@react-three/fiber": "^9.1.2",
    "@react-three/drei": "^10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.3",
    "@types/express": "^5.0.2",
    "@types/ws": "^8.18.1",
    "@types/leaflet": "^1.9.16",
    "@types/three": "^0.175.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "vite": "^6.3.4",
    "tsx": "^4.19.4",
    "concurrently": "^9.1.2"
  }
}

{
  "name": "cubyz-map-viewer",
  "version": "1.1.0",
  "description": "Interactive 2D & 3D map viewer for Cubyz worlds",
  "type": "module",
  "scripts": {
    "check": "biome check .",
    "check:write": "biome check --write .",
    "check:knip": "knip",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "node --import tsx --test test/voxel/server/*.test.ts test/voxel/client/*.test.ts test/voxel/contract/*.test.ts test/core/server/*.test.ts test/core/client/*.test.ts test/core/contract/*.test.ts",
    "test:voxel:server": "node --import tsx --test test/voxel/server/*.test.ts",
    "test:voxel:client": "node --import tsx --test test/voxel/client/*.test.ts",
    "test:voxel:contract": "node --import tsx --test test/voxel/contract/*.test.ts",
    "test:core:service-api": "node --import tsx --test test/core/server/voxel-mesh-service.test.ts test/core/server/voxels-router.test.ts",
    "test:core:watcher": "node --import tsx --test test/core/server/save-watcher.test.ts",
    "test:core:client": "node --import tsx --test test/core/client/live-updates.test.ts",
    "test:core:terrain": "node --import tsx --test test/core/contract/terrain-seam.test.ts",
    "bench:voxel:server": "node --import tsx --test test/voxel/benchmarks/voxel-server.bench.ts",
    "bench:voxel:client": "node --import tsx --test test/voxel/benchmarks/voxel-client.bench.ts",
    "bench:voxel:real-save": "node scripts/benchmark-real-save-voxel-memory.mjs",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "validate:voxel-lighting": "node scripts/capture-isolated-voxel-lighting.mjs",
    "start": "node dist/server/index.js",
    "release": "./scripts/release.sh",
    "release:dry-run": "./scripts/release.sh --dry-run",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2",
    "chokidar": "^4.0.3",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.33.5",
    "three": "^0.175.0",
    "winston": "^3.19.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.2",
    "@types/express-serve-static-core": "^5.1.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/three": "^0.175.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "commit-and-tag-version": "^12.7.1",
    "concurrently": "^9.1.2",
    "knip": "^6.4.1",
    "playwright": "^1.61.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.4"
  }
}

# Cubyz Map Viewer server environment variables.

# HTTP port the server listens on.
PORT=3001

# Host/interface to bind.
HOST=0.0.0.0

# In-memory voxel mesh cache size.
# Recommended for hosting: 1024 or higher for larger visible voxel working sets.
VOXEL_MEMORY_CACHE_SIZE=1024

# Minimum time in ms between full voxel cache clears after broad terrain updates.
VOXEL_FULL_CLEAR_THROTTLE_MS=1000

# Save watcher batch window in ms for terrain updates.
TERRAIN_UPDATE_BATCH_MS=15000

# Quiet-period batch window in ms for player update checks before broadcasting.
PLAYER_UPDATE_BATCH_MS=1000

# Players modified within this window remain visually active.
PLAYER_ACTIVE_WINDOW_MS=60000

# Players older than this window are omitted from /api/players.
PLAYER_RETENTION_MS=300000

# Comma-separated list of allowed browser origins for cross-origin API access.
CORS_ALLOWED_ORIGINS=

# Cubyz save directory.
# If unset, the server auto-detects the newest save under ~/.cubyz/saves/.
SAVE_PATH=

# Cubyz project root or asset source.
# If unset, the server auto-detects the repository parent that contains assets/cubyz.
CUBYZ_PATH=

# Voxel worker pool size.
# If unset, the server uses floor(availableParallelism() / 2) workers.
VOXEL_WORKERS=

# Persistent voxel mesh cache directory.
VOXEL_CACHE_DIR=dist/server/cache/voxels

# Whether to pre-generate voxel caches on startup in the background.
# This warms the persistent disk cache and the in-memory voxel mesh cache.
VOXEL_PREGENERATE_ON_STARTUP=false

# Directory for Winston log files.
LOG_DIR=logs

# Whether to write request-level HTTP entries to server-requests.log.
LOG_REQUESTS=false

# Winston log level.
# Controls console and general file logging verbosity.
LOG_LEVEL=info

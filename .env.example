# Cubyz Map Viewer server environment variables.

# HTTP port the server listens on.
PORT=3001

# Host/interface to bind.
HOST=0.0.0.0

# In-memory voxel mesh cache entry and retained-buffer limits.
VOXEL_MEMORY_CACHE_SIZE=1024
VOXEL_MEMORY_CACHE_BYTES=268435456

# Main-isolate resolved emitter-summary entry and estimated-byte limits.
VOXEL_EMITTER_SUMMARY_CACHE_SIZE=512
VOXEL_EMITTER_SUMMARY_CACHE_BYTES=67108864

# Per-worker represented-emitter resolved-cache limits.
VOXEL_WORKER_EMITTER_CACHE_SIZE=64
VOXEL_WORKER_EMITTER_CACHE_SOURCES=16384

# Idle-worker recycling thresholds. Zero explicitly disables a threshold.
# External/ArrayBuffer defaults are 512 MiB and completed jobs defaults to 32.
VOXEL_WORKER_RECYCLE_HEAP_BYTES=0
VOXEL_WORKER_RECYCLE_EXTERNAL_BYTES=536870912
VOXEL_WORKER_RECYCLE_ARRAY_BUFFER_BYTES=536870912
VOXEL_WORKER_RECYCLE_JOBS=32

# Minimum time in ms between full voxel cache clears after broad terrain updates.
VOXEL_FULL_CLEAR_THROTTLE_MS=1000

# Save watcher batch window in ms for terrain updates.
TERRAIN_UPDATE_BATCH_MS=15000

# Quiet-period batch window in ms for player update checks before broadcasting.
PLAYER_UPDATE_BATCH_MS=1000

# Players modified within this window remain visually active.
PLAYER_ACTIVE_WINDOW_MS=60000

# Players older than this window are omitted from /api/players.
PLAYER_RETENTION_MS=300000

# Comma-separated list of allowed browser origins for cross-origin API access.
CORS_ALLOWED_ORIGINS=

# Cubyz save directory.
# If unset, the server auto-detects the newest save under ~/.cubyz/saves/.
SAVE_PATH=

# Cubyz project root or asset source.
# If unset, the server auto-detects the repository parent that contains assets/cubyz.
CUBYZ_PATH=

# Shared voxel worker-pool and cold LOD 1 emitter-summary build limit.
# If unset, the server uses 1. Higher values improve fresh-cache throughput
# while increasing overlapping main-isolate work and memory use.
VOXEL_WORKERS=

# Maximum queued distinct voxel worker jobs. Running and shared jobs are excluded.
VOXEL_QUEUE_LIMIT=8

# Preferred voxel response encoding.
# Use `br` for smaller payloads when CPU is less constrained.
# Use `gzip` when you want faster compression and can accept slightly larger responses.
VOXEL_PREFERRED_ENCODING=br

# Voxel response compression tuning.
VOXEL_BROTLI_QUALITY=6
VOXEL_BROTLI_LGWIN=11
VOXEL_GZIP_LEVEL=3

# Persistent voxel mesh cache directory.
VOXEL_CACHE_DIR=dist/server/cache/voxels

# Whether to pre-generate voxel caches on startup in the background.
# This warms the persistent disk cache and the in-memory voxel mesh cache.
VOXEL_PREGENERATE_ON_STARTUP=false

# Directory for Winston log files.
LOG_DIR=logs

# Whether to write request-level HTTP entries to server-requests.log.
LOG_REQUESTS=false

# Winston log level.
# Controls console and general file logging verbosity.
LOG_LEVEL=info
